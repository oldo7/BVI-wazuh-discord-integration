#!/bin/bash
read INPUT

SRCIP=$(echo "$INPUT" | grep -o '"srcip":"[^"]*"' | cut -d'"' -f4)
TIMEOUT=$(echo "$INPUT" | grep -o '"timeout":[0-9]*' | cut -d':' -f2)

if [ -z "$TIMEOUT" ]; then
    TIMEOUT=60
fi

if [ -n "$SRCIP" ]; then
    /sbin/iptables -A INPUT -s "$SRCIP" -j DROP
    (sleep "$TIMEOUT" && /sbin/iptables -D INPUT -s "$SRCIP" -j DROP) &
fi

exit 0
