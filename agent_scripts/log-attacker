#!/bin/bash
read INPUT

SRCIP=$(echo "$INPUT" | grep -o '"srcip":"[^"]*"' | cut -d'"' -f4)
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')
LOG_FILE="/var/ossec/logs/attacker_intel.log"

if [ -n "$SRCIP" ]; then
    {
        echo "=========== $TIMESTAMP ==========="
        echo "Target IP: $SRCIP"

        echo "--- WHOIS ---"
        whois "$SRCIP" | head -30

        echo "--- Reverse DNS ---"
        nslookup "$SRCIP"

        if command -v geoiplookup &> /dev/null; then
            echo "--- Geolocation ---"
            geoiplookup "$SRCIP"
        fi

        echo "--- Traceroute ---"
        tracepath "$SRCIP" 2>/dev/null || traceroute "$SRCIP" 2>/dev/null || echo "traceroute not available"

        echo "--- Ping ---"
        ping -c 4 "$SRCIP"

        echo ""
    } >> "$LOG_FILE"
fi

exit 0
